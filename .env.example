# Copy this file to .env for local-only integration test settings.
# The .env file is git-ignored and safe for API credentials.

# Enables the live integration tests in OKX.Api.Tests
OKX_RUN_INTEGRATION_TESTS=false

# Prefer demo trading credentials unless you intentionally want live trading endpoints
OKX_DEMO_TRADING=true

# Optional private API credentials for authenticated integration tests
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=

# Optional public test override
OKX_PUBLIC_BORROW_CURRENCY=BTC
OKX_PUBLIC_EVENTS_SERIES_ID=BTC-ABOVE-DAILY

# Optional live fixture capture overrides
# The capture script always saves Production snapshots.
# When OKX_DEMO_TRADING=true it also saves Demo snapshots with x-simulated-trading: 1.
OKX_CAPTURE_PUBLIC_OPTION_ULY=BTC-USD
OKX_CAPTURE_PUBLIC_EVENTS_SERIES_ID=BTC-ABOVE-DAILY
OKX_CAPTURE_PUBLIC_BORROW_CURRENCY=BTC
OKX_CAPTURE_PUBLIC_FUNDING_HISTORY_XPERP_INST_ID=
OKX_CAPTURE_PUBLIC_SPREAD_ID=
OKX_CAPTURE_PUBLIC_INSURANCE_INST_TYPE=SWAP
OKX_CAPTURE_PUBLIC_INSURANCE_INST_FAMILY=BTC-USD
OKX_CAPTURE_PUBLIC_OPEN_INTEREST_INST_TYPE=SWAP
OKX_CAPTURE_PUBLIC_OPEN_INTEREST_INST_ID=BTC-USDT-SWAP
OKX_CAPTURE_PUBLIC_INDEX_ID=BTC-USD
OKX_CAPTURE_PUBLIC_ECONOMIC_REGION=united_states
